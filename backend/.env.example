# Backend environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MySQL password for spring.datasource.username (default: root)
SPRING_DATASOURCE_PASSWORD=your_mysql_password_here

# Google OAuth (needed for Google login / Google Forms features)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/profile/google-callback

# Gemini API (for the AI summary feature)
# Get an API key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model used by the AI assistant
GEMINI_MODEL=gemini-2.0-flash
